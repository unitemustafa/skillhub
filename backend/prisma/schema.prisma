generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                String               @default("admin")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  players             Player[]
  subscriptions       Subscription[]
  evaluations         Evaluation[]
  financeTransactions FinanceTransaction[]
  messages            Message[]
  notifications       Notification[]
}

model Player {
  id               String         @id
  name             String
  birthDate        DateTime
  phone            String
  guardianName     String
  guardianRelation String
  guardianJob      String?
  isActive         Boolean        @default(false)
  ownerId          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  owner            User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  subscriptions    Subscription[]
  evaluations      Evaluation[]
  messages         Message[]

  @@index([ownerId])
  @@index([ownerId, name])
  @@index([ownerId, phone])
  @@index([name])
  @@index([phone])
}

model Subscription {
  id        String   @id @default(cuid())
  playerId  String
  ownerId   String
  amount    Float
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, endDate])
  @@index([playerId])
  @@index([endDate])
}

model Evaluation {
  id          String   @id @default(cuid())
  playerId    String
  ownerId     String
  coach       String
  evaluationDate DateTime @default(now())
  fitness     Int
  speed       Int
  skill       Int
  discipline  Int
  teamwork    Int
  notes       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, evaluationDate])
  @@index([playerId])
  @@index([evaluationDate])
}

model FinanceTransaction {
  id          String   @id @default(cuid())
  ownerId     String
  type        String
  category    String
  amount      Float
  description String
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, occurredAt])
  @@index([occurredAt])
}

model Message {
  id          String   @id @default(cuid())
  ownerId     String
  playerId    String?
  recipient   String
  channel     String
  body        String
  status      String   @default("pending")
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  player      Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, createdAt])
  @@index([playerId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  body      String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerId, createdAt])
  @@index([createdAt])
}
